class Solution {
    public void moveZeroes(int[] nums) {
        int i = 0;

        // Move all non-zero elements to the front
        for (int j = 0; j < nums.length; j++) {
            if (nums[j] != 0) {
                int temp = nums[i];
                nums[i] = nums[j];
                nums[j] = temp;
                i++;
            }
        }
    }
}
